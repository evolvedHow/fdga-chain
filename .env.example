# GerryChain API configuration

# Mapbox public token — served to the frontend via GET /api/config
# Restrict to your domain at https://account.mapbox.com/
# For Modal: store in a Modal Secret instead (see modal_app.py)
MAPBOX_TOKEN=

# LLM for narrative generation (optional)
LLM_PROVIDER=ollama/llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434
GROQ_API_KEY=

# LRDB integration (link back to lrdb database/API)
LRDB_DATA_PATH=../lrdb/public/assets/lrdb_web_20260216.geojson

# Chain defaults
DEFAULT_STEPS=10000
DEFAULT_EPSILON=0.05   # ±5% population deviation
